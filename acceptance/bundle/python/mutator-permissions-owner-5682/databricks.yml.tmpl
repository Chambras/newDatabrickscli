bundle:
  name: test-bundle-$UNIQUE_NAME

variables:
  grantee_group:
    default: some-group

python:
  mutators:
    - "mutators:add_pipeline_permission"

resources:
  pipelines:
    my_pipeline:
      name: test-pipeline-$UNIQUE_NAME
      catalog: main
      schema: default
      serverless: true
      libraries:
        - notebook:
            path: ./nb.py
